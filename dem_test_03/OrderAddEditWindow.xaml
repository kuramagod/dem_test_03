<Window x:Class="dem_test_03.OrderAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dem_test_03"
        mc:Ignorable="d"
        FontFamily="Times New Roman"
        WindowStartupLocation="CenterScreen"
        Title="OrderAddEditWindow" Height="400" Width="800">
    <StackPanel Margin="20">

        <TextBlock Text="ID" x:Name="IdBox"/>

        <TextBlock Text="Артикл"/>
        <ComboBox x:Name="ProductBox"/>

        <TextBlock Text="Статус"/>
        <ComboBox x:Name="StatusBox"/>

        <TextBlock Text="Адрес пункта выдачи"/>
        <ComboBox x:Name="PickpointAddressBox"/>

        <TextBlock Text="Дата заказа"/>
        <TextBox x:Name="OrderDateBox"/>

        <TextBlock Text="Дата выдачи"/>
        <TextBox x:Name="DeliveryDateBox"/>

        <Button Content="Сохранить" Margin="0,20,0,0" Click="SaveButton"/>
        <Button Content="Удалить" x:Name="DeleteBut" Margin="0,20,0,0" Click="DeleteButton"/>
    </StackPanel>
</Window>
