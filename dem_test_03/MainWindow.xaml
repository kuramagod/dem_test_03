<Window x:Class="dem_test_03.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dem_test_03"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        FontFamily="Times New Roman"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <DataTemplate x:Key="ProductTemplate">
            <Border BorderBrush="#7FFF00" BorderThickness="1" Background="{Binding BackgroundColor}" Margin="10" Padding="10" MouseLeftButtonDown="Product_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Source="/images/picture.png" Width="70" Height="80"/>
                    <Image Source="{Binding Photo}" Width="120" Height="80"/>
                    <StackPanel Grid.Column="1" Margin="10, 0">
                        <TextBlock>
                            <Run Text="{Binding Category.Name}"/>
                            <Run Text="{Binding Name}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Description, StringFormat=Описание товара: {0}}"/>
                        <TextBlock Text="{Binding Manufacturer.Name, StringFormat=Производитель: {0}}"/>
                        <TextBlock Text="{Binding Supplier.Name, StringFormat=Поставщик: {0}}"/>
                        <TextBlock Text="{Binding Price, StringFormat=Цена: {0} рублей}"/>
                        <TextBlock Text="{Binding Unit, StringFormat=Еденица измерения: {0}}"/>
                        <TextBlock Text="{Binding Quantity, StringFormat=Колличество на складе: {0}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10, 0, 0, 0">
                        <TextBlock>
                            Действующая<LineBreak/>скидка <Run Text="{Binding Discount, StringFormat={}{0}%}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="OrderTemplate">
            <Border BorderBrush="#7FFF00" BorderThickness="1" Margin="10" Padding="10" MouseLeftButtonDown="Order_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Margin="10, 0">
                        <TextBlock Text="{Binding Code, StringFormat=Артикул заказа {0}}" />
                        <TextBlock Text="{Binding Status, StringFormat=Статус заказа {0}}"/>
                        <TextBlock Text="{Binding Pickpoint.Name, StringFormat=Адрес пункта выдачи({0})}"/>
                        <TextBlock Text="{Binding OrderDate, StringFormat=Дата заказа {0}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10, 0, 0, 0">
                        <TextBlock Text="{Binding DeliveryDate, StringFormat=Дата доставки {0}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <ScrollViewer>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Image Source="/images/Icon.png" Width="80" Height="80" HorizontalAlignment="Left" Margin="10,10"/>
                <TextBlock x:Name="UserFullname" FontSize="15" VerticalAlignment="Center" Margin="10,0"/>
                <Button Content="На главную" Width="80" Height="30" Background="#7FFF00" Margin="10,0" Click="ProductButton_Click"/>
                <Button Content="Заказы" Width="80" Height="30" x:Name="OrderButton" Margin="10,10" Background="#7FFF00" Click="OrdersButton_Click"/>
                <Button Content="Выйти" Width="80" Height="30" Background="#7FFF00" Margin="10,0" Click="BackButton_Click"/>
            </StackPanel>
            <TextBlock x:Name="NameZone" FontSize="20" FontWeight="Bold" Margin="10"/>
            <StackPanel Orientation="Horizontal" Margin="8">
                <StackPanel x:Name="ProductOptionsPanel" Orientation="Horizontal">
                    <TextBox x:Name="SearchTextBox" Width="180" Margin="10,0" TextChanged="ProductViewChanged"/>

                    <ComboBox x:Name="SupplierSortComboBox" Background="#00FA9A" Width="130" Margin="10,0" SelectionChanged="ProductViewChanged"/>

                    <ComboBox x:Name="UnitSortComboBox" Background="#00FA9A" Width="190" Margin="10,0" SelectionChanged="ProductViewChanged">
                        <ComboBoxItem Content="Без сортировки"/>
                        <ComboBoxItem Content="По возрастанию"/>
                        <ComboBoxItem Content="По убыванию"/>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="AddProductButton" Background="#00FA9A" Content="Добавить товар" Click="AddProductButton_Click"/>
                <Button x:Name="AddOrderButton" Background="#00FA9A" Content="Добавить заказ" Click="AddOrderButton_Click"/>
            </StackPanel>
            <ItemsControl x:Name="ProductList"/>
        </StackPanel>
    </ScrollViewer>
</Window>