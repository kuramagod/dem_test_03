<Window x:Class="dem_test_03.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dem_test_03"
        mc:Ignorable="d"
        FontFamily="Times New Roman"
        WindowStartupLocation="CenterScreen"
        Title="ProductEditWindow" Height="450" Width="800">
    <StackPanel Margin="20">

        <TextBlock Text="ID" x:Name="IdBox"/>

        <TextBlock Text="Наименование товара"/>
        <TextBox x:Name="NameBox"/>

        <TextBlock Text="Категория"/>
        <ComboBox x:Name="CategoryBox"/>

        <TextBlock Text="Описание"/>
        <TextBox x:Name="DescriptionBox"/>

        <TextBlock Text="Производитель"/>
        <ComboBox x:Name="ManufacturerBox"/>

        <TextBlock Text="Поставщик"/>
        <ComboBox x:Name="SupplierBox"/>

        <TextBlock Text="Цена"/>
        <TextBox x:Name="PriceBox"/>

        <TextBlock Text="Unit"/>
        <TextBox x:Name="UnitBox"/>

        <TextBlock Text="Колличество на складе"/>
        <TextBox x:Name="QuantityBox"/>

        <TextBlock Text="Скидка"/>
        <TextBox x:Name="DiscountBox"/>

        <Button Content="Сохранить" Margin="0,20,0,0" Click="SaveButton"/>
        <Button Content="Удалить" x:Name="DeleteBut" Margin="0,20,0,0" Click="DeleteButton"/>
    </StackPanel>
</Window>
